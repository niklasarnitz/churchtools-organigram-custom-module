{
	"name": "churchtools-organigram-custom-module",
	"version": "1.3.0-bwl21",
	"private": true,
	"dependencies": {
		"@churchtools/churchtools-client": "^1.6.0",
		"@fontsource/lato": "^5.2.7",
		"@radix-ui/react-collapsible": "^1.1.12",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-popover": "^1.1.15",
		"@radix-ui/react-select": "^2.2.6",
		"@radix-ui/react-slot": "^1.2.4",
		"@radix-ui/react-switch": "^1.2.6",
		"@tanstack/query-async-storage-persister": "^5.90.24",
		"@tanstack/query-sync-storage-persister": "^5.90.24",
		"@tanstack/react-query": "^5.90.21",
		"@tanstack/react-query-persist-client": "^5.90.24",
		"@types/node": "^25.3.3",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"axios-cookiejar-support": "^6.0.5",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"dom-to-svg": "^0.12.2",
		"elkjs": "^0.11.0",
		"lodash": "^4.17.23",
		"lucide-react": "^0.576.0",
		"moment": "^2.30.1",
		"react": "^19.2.4",
		"react-contexify": "^6.0.0",
		"react-dom": "^19.2.4",
		"tailwind-merge": "^3.5.0",
		"tough-cookie": "^6.0.0",
		"typescript": "^5.9.3",
		"zustand": "^5.0.11"
	},
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build",
		"build:module": "PACKAGE_VERSION=$(cat package.json | jq -r '.version') && rm -rf build/* && rm -rf organigram-${PACKAGE_VERSION}.zip && npm run build && zip -r organigram-${PACKAGE_VERSION}.zip build/ && echo 'You can now upload the organigram.zip to your churchtools instance. Hint: Please keep in mind to use organigram as the shorty.'",
		"preview": "vite preview",
		"deploy": "bun scripts/deploy.ts",
		"seed": "bun scripts/seed-testdata.ts",
		"changelog": "bun scripts/generate-changelog.ts",
		"lint": "eslint src/",
		"ci": "bun run lint && bun run typecheck",
		"typecheck": "tsc --noEmit",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{js,ts,tsx}": [
			"eslint --fix",
			"prettier --write"
		],
		"*.{json,css,md}": [
			"prettier --write"
		]
	},
	"devDependencies": {
		"@ainias42/js-helper": "^0.8.19",
		"@eslint/js": "^10.0.1",
		"@tailwindcss/vite": "^4.2.1",
		"@the-unicorns/prettier-config": "^1.0.2",
		"@types/lodash": "^4.17.24",
		"@types/tough-cookie": "^4.0.5",
		"@vitejs/plugin-react": "^5.1.4",
		"eslint": "^10.0.2",
		"eslint-plugin-perfectionist": "^5.6.0",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-react-hooks": "^7.0.1",
		"globals": "^17.4.0",
		"husky": "^9.1.7",
		"jiti": "^2.6.1",
		"lint-staged": "^16.3.2",
		"prettier": "^3.8.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"tailwindcss": "^4.2.1",
		"tw-animate-css": "^1.4.0",
		"typescript-eslint": "^8.56.1",
		"vite": "^7.3.1",
		"web-worker": "^1.5.0"
	}
}
